	Block {
	  BlockType		  SubSystem
	  Name			  "EulerXYZ"
	  Ports			  [1, 1]
	  Position		  [205, 57, 260, 103]
	  AncestorBlock		  "aerospace/Axes\nTransformations/Direction C"
"osine Matrix\nfrom Euler Angles"
	  ShowPortLabels	  off
	  TreatAsAtomicUnit	  off
	  MaskType		  "EulerXYZ"
	  MaskDescription	  "Creates the EulerXYZ rotation matrix corres"
"ponding to body fixed rotations in the X, Y, and then Z. This matrix maps bod"
"y vectors to world vectors. "
	  MaskHelp		  "<p>This block determines the EulerXYZ matri"
"x from a 3x1 euler angles in the X, Y, & Z directions. The matrix maps vector"
"s the body axes to the inertial axes.</p>\n\n<p>The block input and output co"
"ntain more than one signal as described below.</p>\n\n<p><H4>Block Vector Inp"
"ut - Euler XYZ angles</H4>\n    <ul>\n    <li>X angle</li>\n    <li>Y angle</"
"li>\n    <li>Z angle</li>\n   </ul>\n   </p>\n\n<p><H4>Block Matrix Output - "
"XYZ Euler Matrix </H4>\n    <ul>\n   </ul>\n   </p>\n"
	  MaskDisplay		  "disp('Rotation\\nMatrix')"
	  MaskIconFrame		  on
	  MaskIconOpaque	  on
	  MaskIconRotate	  "none"
	  MaskIconUnits		  "autoscale"
	  System {
	    Name		    "EulerXYZ"
	    Location		    [67, 99, 762, 550]
	    Open		    off
	    ModelBrowserVisibility  off
	    ModelBrowserWidth	    200
	    ScreenColor		    "white"
	    PaperOrientation	    "landscape"
	    PaperPositionMode	    "auto"
	    PaperType		    "usletter"
	    PaperUnits		    "inches"
	    ZoomFactor		    "100"
	    Block {
	      BlockType		      Inport
	      Name		      "x\ny\nz\nangles"
	      Position		      [20, 20, 40, 40]
	    }
	    Block {
	      BlockType		      Fcn
	      Name		      "11"
	      Position		      [105, 19, 380, 41]
	      Expr		      "cos(u[2])*cos(u[3])"
	    }
	    Block {
	      BlockType		      Fcn
	      Name		      "12"
	      Position		      [105, 139, 380, 161]
	      Expr		      "-cos(u[2])*sin(u[3])"
	    }
	    Block {
	      BlockType		      Fcn
	      Name		      "13"
	      Position		      [105, 259, 380, 281]
	      Expr		      "sin(u[2])"
	    }
	    Block {
	      BlockType		      Fcn
	      Name		      "21"
	      Position		      [105, 59, 380, 81]
	      Expr		      "cos(u[3])*sin(u[2])*sin(u[1])+cos(u[1])"
"*sin(u[3])"
	    }
	    Block {
	      BlockType		      Fcn
	      Name		      "22"
	      Position		      [105, 179, 380, 201]
	      Expr		      "cos(u[1])*cos(u[3]) - sin(u[1])*sin(u[2"
"])*sin(u[3])"
	    }
	    Block {
	      BlockType		      Fcn
	      Name		      "23"
	      Position		      [105, 299, 380, 321]
	      Expr		      "-sin(u[1])*cos(u[2])"
	    }
	    Block {
	      BlockType		      Fcn
	      Name		      "31"
	      Position		      [105, 99, 380, 121]
	      Expr		      "sin(u[1])*sin(u[3]) - cos(u[1])*cos(u[3"
"])*sin(u[2])"
	    }
	    Block {
	      BlockType		      Fcn
	      Name		      "32"
	      Position		      [105, 219, 380, 241]
	      Expr		      "cos(u[3])*sin(u[1])+cos(u[1])*sin(u[2])"
"*sin(u[3])"
	    }
	    Block {
	      BlockType		      Fcn
	      Name		      "33"
	      Position		      [105, 339, 380, 361]
	      Expr		      "cos(u[1])*cos(u[2])"
	    }
